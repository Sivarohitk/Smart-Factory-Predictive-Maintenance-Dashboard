MYSQL_DATABASE=smart_factory
MYSQL_USER=smart_factory_user
MYSQL_PASSWORD=smart_factory_password
MYSQL_ROOT_PASSWORD=root_password
DATABASE_URL=mysql+pymysql://smart_factory_user:smart_factory_password@db:3306/smart_factory
APP_ENV=development
APP_NAME=Smart Factory Predictive Maintenance Dashboard
ALERT_PROBABILITY_THRESHOLD=0.54
CORS_ORIGINS=["http://localhost:5173"]
AUTO_CREATE_TABLES=true
DATABASE_CONNECT_MAX_ATTEMPTS=20
DATABASE_CONNECT_RETRY_SECONDS=2
